# Example environment variables for Guiced Telemetry
# Copy to .env and adjust values for local development.

# Service identity
SERVICE_NAME=guiced-telemetry
SERVICE_ENV=dev
SERVICE_REGION=local

# OpenTelemetry exporter configuration
# Base endpoint (the signal sub-path /v1/traces or /v1/logs is appended automatically).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Per-signal overrides (full URLs, used verbatim). Tempo/Jaeger only accept traces;
# send logs to a logs-capable backend (Loki / OTel Collector) or disable log export.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://tempo:4318/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://loki:3100/otlp/v1/logs
# Set to false for traces-only backends (e.g. Tempo) to skip OTLP log export and avoid 404 /v1/logs.
# TELEMETRY_EXPORT_LOGS=false

OTEL_SERVICE_NAME="${SERVICE_NAME}"
OTEL_RESOURCE_ATTRIBUTES="service.version=0.0.1,service.environment=${SERVICE_ENV}"

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# HTTP server (if applicable)
HTTP_PORT=8080

# See docs/GUIDES.md and ../rules/generative/platform/secrets-config/env-variables.md for guidance.
